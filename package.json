{
  "name": "ddna-reader",
  "version": "0.2.0",
  "description": "Read-only tools for .ddna envelope inspection, validation, and verification",
  "type": "module",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "bin": {
    "ddna-reader": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist",
    "test-fixtures",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ddna",
    "deepadata",
    "edm",
    "emotional-data-model",
    "inspection",
    "validation",
    "verification",
    "ed25519",
    "data-integrity",
    "read-only"
  ],
  "author": "Deepadata",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emotional-data-model/ddna-reader.git"
  },
  "bugs": {
    "url": "https://github.com/emotional-data-model/ddna-reader/issues"
  },
  "homepage": "https://github.com/emotional-data-model/ddna-reader#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "canonicalize": "^2.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "multiformats": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
